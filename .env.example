# Backend server
SERVER_PORT=8080
SERVER_ADDRESS=0.0.0.0

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ais_taxi
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me

# JPA / SQL init
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_SQL_INIT_MODE=always

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# JWT
APP_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
APP_JWT_EXPIRATION_MS=86400000

# Default admin bootstrap
APP_ADMIN_PHONE=+996700000000
APP_ADMIN_PASSWORD=change_me
APP_ADMIN_FULL_NAME=System Admin
