{
  "info": {
    "name": "AIS Taxi Admin Panel",
    "description": "API collection for testing admin panel functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"adminToken\", jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+996700000000\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Driver Applications (Public)",
      "item": [
        {
          "name": "Submit Driver Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Иван Иванов\",\n  \"phone\": \"+996700000001\",\n  \"email\": \"ivan@example.com\",\n  \"licenseNumber\": \"ABC123456\",\n  \"licenseExpiry\": \"2027-12-31\",\n  \"vehicleMake\": \"Toyota\",\n  \"vehicleModel\": \"Camry\",\n  \"vehicleYear\": 2020,\n  \"vehiclePlate\": \"01ABC123\",\n  \"carClass\": \"COMFORT\",\n  \"notes\": \"Опыт вождения 5 лет\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/driver-applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "driver-applications"]
            }
          }
        },
        {
          "name": "Get Application Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/driver-applications/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "driver-applications", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Admin - Dashboard",
      "item": [
        {
          "name": "Get Dashboard Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard", "metrics"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Admin - Driver Applications",
      "item": [
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications"]
            }
          }
        },
        {
          "name": "Get Pending Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          }
        },
        {
          "name": "Get Application by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications", "1"]
            }
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications/1/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications", "1", "approve"]
            }
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications/1/reject?reason=Недостаточный опыт вождения",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications", "1", "reject"],
              "query": [
                {
                  "key": "reason",
                  "value": "Недостаточный опыт вождения"
                }
              ]
            }
          }
        },
        {
          "name": "Activate Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/driver-applications/1/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "driver-applications", "1", "activate"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Admin - Driver Management",
      "item": [
        {
          "name": "Verify Driver Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/drivers/2/verify-documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "drivers", "2", "verify-documents"]
            }
          }
        },
        {
          "name": "Reject Driver Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/drivers/2/reject-documents?reason=Фото водительского удостоверения нечеткое",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "drivers", "2", "reject-documents"],
              "query": [
                {
                  "key": "reason",
                  "value": "Фото водительского удостоверения нечеткое"
                }
              ]
            }
          }
        },
        {
          "name": "Terminate Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/drivers/2/terminate?reason=Нарушение правил сервиса",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "drivers", "2", "terminate"],
              "query": [
                {
                  "key": "reason",
                  "value": "Нарушение правил сервиса"
                }
              ]
            }
          }
        },
        {
          "name": "Reactivate Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/drivers/2/reactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "drivers", "2", "reactivate"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Admin - User Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Get Drivers Only",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users?role=DRIVER",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"],
              "query": [
                {
                  "key": "role",
                  "value": "DRIVER"
                }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "2"]
            }
          }
        },
        {
          "name": "Ban User (Temporary)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/2/ban?durationHours=24&reason=Нарушение правил",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "2", "ban"],
              "query": [
                {
                  "key": "durationHours",
                  "value": "24"
                },
                {
                  "key": "reason",
                  "value": "Нарушение правил"
                }
              ]
            }
          }
        },
        {
          "name": "Ban User (Permanent)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/2/ban?reason=Серьезное нарушение",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "2", "ban"],
              "query": [
                {
                  "key": "reason",
                  "value": "Серьезное нарушение"
                }
              ]
            }
          }
        },
        {
          "name": "Unban User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/2/unban",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "2", "unban"]
            }
          }
        }
      ]
    },
    {
      "name": "7. Admin - Audit Logs",
      "item": [
        {
          "name": "Get All Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"]
            }
          }
        },
        {
          "name": "Get Logs by Action",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?action=APPROVE_DRIVER_APPLICATION",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [
                {
                  "key": "action",
                  "value": "APPROVE_DRIVER_APPLICATION"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
